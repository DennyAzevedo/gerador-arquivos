# Banco de dados (PostgreSQL) - container existente publicado no host
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=sua_senha
POSTGRES_DB=gerador_artigos

# Conexao usada pelo backend.
# host.docker.internal = maquina host (onde o Postgres esta publicado na porta 5432)
DATABASE_URL=postgresql+asyncpg://seu_usuario:sua_senha@host.docker.internal:5432/gerador_artigos

# OpenAI
OPENAI_API_KEY=sk-troque-esta-chave
OPENAI_MODEL=gpt-4o-mini

# Autenticacao
JWT_SECRET=troque-este-segredo

# CORS (origens permitidas pelo backend)
CORS_ORIGINS=http://localhost:5173

# Frontend (URL do backend acessada pelo navegador)
VITE_API_URL=http://localhost:8000
