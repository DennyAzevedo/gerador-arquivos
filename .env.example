# =============================================================================
# Copie este arquivo para .env e preencha com valores reais:
#   cp .env.example .env
#
# IMPORTANTE: o arquivo .env NAO deve ser commitado (ja esta no .gitignore).
# =============================================================================

# Banco de dados (PostgreSQL) - instancia existente publicada no host
POSTGRES_USER=seu_usuario
POSTGRES_PASSWORD=sua_senha
POSTGRES_DB=gerador_artigos

# Conexao usada pelo backend (dentro do container Docker).
# host.docker.internal = maquina host onde o Postgres esta na porta 5432.
# Se a senha contiver caracteres especiais (ex.: @), codifique na URL (@ -> %40).
DATABASE_URL=postgresql+asyncpg://seu_usuario:sua_senha@host.docker.internal:5432/gerador_artigos

# OpenAI
OPENAI_API_KEY=sk-troque-esta-chave
OPENAI_MODEL=gpt-4o-mini

# Autenticacao (use ao menos 32 caracteres em producao)
JWT_SECRET=troque-este-segredo-com-pelo-menos-32-caracteres

# CORS (origens permitidas pelo backend, separadas por virgula se multiplas)
CORS_ORIGINS=http://localhost:5173

# Frontend (URL do backend acessada pelo navegador)
VITE_API_URL=http://localhost:8000

# Banco de testes (opcional, usado apenas ao rodar pytest)
# TEST_DATABASE_URL=postgresql+asyncpg://seu_usuario:sua_senha@host.docker.internal:5432/gerador_artigos_test
